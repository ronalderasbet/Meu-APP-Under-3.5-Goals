name: Build Flet APK
on:
  push:
    branches: [ main ] # Roda sempre que você der push na branch main

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install Flet and Dependencies
        run: |
          pip install flet httpx

      - name: Setup Flutter
        uses: subosito/flutter-action@v2
        with:
          flutter-version: '3.19.0'
          channel: 'stable'

      - name: Build APK
        run: |
          # O comando 'flet build apk' gera o arquivo para Android
          flet build apk --main main.py

      - name: Upload APK Artifact
        uses: actions/upload-artifact@v4
        with:
          name: football-app-apk
          path: build/apk/*.apk
